APP_NAME=real-time-news-alert-system
ENVIRONMENT=development
LOG_LEVEL=INFO

API_HOST=0.0.0.0
API_PORT=8000

REDIS_URL=redis://redis:6379/0
REDIS_STREAM=news_stream
REDIS_DLQ_STREAM=news_stream:dlq
REDIS_CONSUMER_GROUP=alert-workers
REDIS_CONSUMER_NAME=worker-1
REDIS_RECENT_WINDOW_SECONDS=3600
REDIS_MESSAGE_IDEMPOTENCY_TTL=86400
REDIS_CONSUMER_BATCH_SIZE=50
REDIS_CONSUMER_MAX_RETRIES=5
REDIS_CONSUMER_RETRY_BACKOFF_SECONDS=0.5

POSTGRES_DSN=postgresql+asyncpg://postgres:postgres@postgres:5432/news_alerts

NEWSAPI_KEY=
ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_NEWS_URL=https://data.alpaca.markets/v1beta1/news
SEC_RSS_URL=https://www.sec.gov/cgi-bin/browse-edgar?action=getcurrent&output=atom
NEWSAPI_URL=https://newsapi.org/v2/top-headlines
NEWS_POLL_INTERVAL_SECONDS=30
HTTP_TIMEOUT_SECONDS=15
MAX_FETCH_RETRIES=3

DEDUP_SIMILARITY_THRESHOLD=0.92
DEDUP_NEIGHBORHOOD_SIZE=200
DEDUP_TTL_SECONDS=86400
EMBEDDING_CACHE_TTL_SECONDS=86400

EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
CLASSIFIER_MIN_CONFIDENCE=0.30
CLASSIFIER_KEYWORD_THRESHOLD=0.55
CLASSIFIER_EMBEDDING_THRESHOLD=0.42
CLASSIFIER_OTHER_MAX_CONFIDENCE=0.45

PORTFOLIO_MATCH_CACHE_TTL_SECONDS=3600

WEBHOOK_TIMEOUT_SECONDS=10
DELIVERY_RETRY_ATTEMPTS=3
DELIVERY_RETRY_BASE_DELAY_SECONDS=0.5
DELIVERY_RETRY_MAX_DELAY_SECONDS=8
DELIVERY_FAILURE_STREAM=notification_delivery_failures
DELIVERY_WEBHOOK_RATE_LIMIT_PER_SECOND=20
DELIVERY_SLACK_RATE_LIMIT_PER_SECOND=1
DELIVERY_EMAIL_RATE_LIMIT_PER_SECOND=10
DELIVERY_REPLAY_GROUP=delivery-replay-workers
DELIVERY_REPLAY_CONSUMER_NAME=delivery-replay-1
DELIVERY_REPLAY_BATCH_SIZE=25
DELIVERY_REPLAY_MAX_ATTEMPTS=5

SMTP_HOST=localhost
SMTP_PORT=25
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_ADDRESS=alerts@example.com
SMTP_USE_TLS=false

PIPELINE_CONCURRENCY=10
